---
import { cn } from '@/lib/utils'
import type { HTMLAttributes } from 'astro/types'

export interface Props
  extends HTMLAttributes<'h1' | 'h2' | 'h3' | 'h4' | 'h5' | 'h6'> {
  level?: 1 | 2 | 3 | 4 | 5 | 6
  variant?: 'default' | 'hero' | 'section' | 'subsection'
  align?: 'left' | 'center' | 'right'
  kicker?: string
  class?: string
}

const {
  level = 2,
  variant = 'default',
  align = 'left',
  kicker,
  class: className = '',
  ...props
} = Astro.props

const headingVariants = {
  default: 'font-semibold text-white',
  hero: 'cetus-wordmark--glow',
  section: 'text-white',
  subsection: 'font-semibold text-white',
}

const headingStyles = {
  default: '',
  hero: 'font-family: var(--cetus-display-font); font-weight: var(--cetus-display-weight); font-style: var(--cetus-display-style);',
  section:
    'font-family: var(--cetus-display-font); font-weight: var(--cetus-display-weight); font-style: var(--cetus-display-style);',
  subsection: '',
}

const sizeVariants = {
  1: 'text-6xl md:text-8xl',
  2: 'text-4xl md:text-5xl',
  3: 'text-3xl md:text-4xl',
  4: 'text-2xl md:text-3xl',
  5: 'text-xl md:text-2xl',
  6: 'text-lg md:text-xl',
}

const alignVariants = {
  left: 'text-left',
  center: 'text-center',
  right: 'text-right',
}

const classes = cn(
  headingVariants[variant],
  sizeVariants[level],
  alignVariants[align],
  className
)

const style = headingStyles[variant]

const Tag = `h${level}` as const
---

{
  kicker && (
    <p class="font-mono text-xs tracking-widest text-cetus-ink-muted uppercase mb-2">
      ▸ {kicker}
    </p>
  )
}
<Tag class={classes} style={style} {...props}>
  <slot />
</Tag>
