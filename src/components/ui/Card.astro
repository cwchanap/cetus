---
import { cn } from '@/lib/utils'
import type { HTMLAttributes } from 'astro/types'

export interface Props extends HTMLAttributes<'div'> {
  variant?: 'default' | 'sci-fi' | 'glass' | 'elevated'
  brackets?: boolean
  class?: string
}

const {
  variant = 'default',
  brackets = false,
  class: className = '',
  ...props
} = Astro.props

const cardVariants = {
  variant: {
    default: 'rounded-lg border bg-card text-card-foreground shadow-sm',
    'sci-fi':
      'group relative bg-cetus-surface rounded-2xl border border-cetus-hairline backdrop-blur-sm hover:border-cetus-accent/60 transition-all duration-300',
    glass:
      'bg-cetus-surface rounded-2xl border border-cetus-hairline backdrop-blur-sm',
    elevated:
      'rounded-lg border bg-card text-card-foreground shadow-lg hover:shadow-xl transition-shadow duration-300',
  },
}

const classes = cn(
  cardVariants.variant[variant],
  brackets && 'hud-bracket-host',
  className
)
---

<div class={classes} {...props}>
  {
    brackets && (
      <>
        <span class="hud-bracket hud-bracket--tl" aria-hidden="true" />
        <span class="hud-bracket hud-bracket--tr" aria-hidden="true" />
        <span class="hud-bracket hud-bracket--bl" aria-hidden="true" />
        <span class="hud-bracket hud-bracket--br" aria-hidden="true" />
      </>
    )
  }
  <slot />
</div>
