---
import Card from '@/components/ui/Card.astro'
import Badge from '@/components/ui/Badge.astro'
import type { UserChallengeProgress } from '@/lib/challenges'

interface Props {
  challenges: UserChallengeProgress[]
  xp: number
  level: number
  xpProgress: number
  xpToNextLevel: number
  streak: number
  resetIn: number
}

const { challenges, xp, level, xpProgress, xpToNextLevel, streak, resetIn } =
  Astro.props

// Difficulty colors
const difficultyColors: Record<string, string> = {
  easy: 'text-cetus-accent',
  medium: 'text-cetus-accent-2',
  hard: 'text-cetus-accent-3',
}
---

<Card variant="glass" class="p-6 mb-8">
  <!-- Header -->
  <div class="flex items-center justify-between mb-6">
    <div class="flex items-center gap-3">
      <span class="text-2xl">🎯</span>
      <h3
        class="text-lg font-bold text-cetus-accent"
        style="font-family: var(--cetus-display-font); font-weight: var(--cetus-display-weight); font-style: var(--cetus-display-style);"
      >
        DAILY MISSIONS
      </h3>
    </div>
    <div class="flex items-center gap-3">
      <Badge variant="outline" size="sm" class="bg-cetus-accent-2/20">
        Level {level}
      </Badge>
      <span
        id="reset-timer"
        class="text-sm text-cetus-ink-muted"
        data-reset-in={resetIn}
      >
        Resets in --:--:--
      </span>
    </div>
  </div>

  <!-- XP Progress Bar -->
  <div class="mb-6">
    <div class="flex justify-between text-sm mb-2">
      <span class="text-cetus-ink-muted">XP Progress</span>
      <span class="text-cetus-accent">{xp} XP</span>
    </div>
    <div
      class="w-full bg-cetus-surface rounded-full h-2 overflow-hidden border border-cetus-hairline"
    >
      <div
        class="h-full bg-cetus-accent transition-all duration-500"
        style={`width: ${xpProgress}%`}
      >
      </div>
    </div>
    <div class="text-xs text-cetus-ink-muted mt-1">
      {xpToNextLevel} XP to Level {level + 1}
    </div>
  </div>

  <!-- Challenge List -->
  <div class="space-y-4">
    {
      challenges.map(challenge => {
        const progress =
          challenge.targetValue && challenge.targetValue > 0
            ? Math.min(
                100,
                (challenge.currentValue / challenge.targetValue) * 100
              )
            : 0
        return (
          <div
            class={`p-4 rounded-xl border transition-all ${
              challenge.completed
                ? 'bg-green-500/10 border-green-500/30'
                : 'bg-cetus-surface border border-cetus-hairline hover:border-cetus-accent/30'
            }`}
          >
            <div class="flex items-start gap-4">
              <span class="text-2xl">{challenge.icon}</span>
              <div class="flex-1 min-w-0">
                <div class="flex items-center gap-2 mb-1">
                  <span class="font-bold text-white">{challenge.name}</span>
                  <span
                    class={`text-xs ${difficultyColors[challenge.difficulty]}`}
                  >
                    {challenge.difficulty.toUpperCase()}
                  </span>
                  {challenge.completed && (
                    <span class="text-green-400 text-sm">✓</span>
                  )}
                </div>
                <p class="text-sm text-cetus-ink-muted mb-2">
                  {challenge.description}
                </p>

                {!challenge.completed && (
                  <div class="flex items-center gap-3">
                    <div class="flex-1 bg-cetus-surface rounded-full h-1.5 overflow-hidden">
                      <div
                        class="h-full bg-cetus-accent transition-all duration-300"
                        style={`width: ${progress}%`}
                      />
                    </div>
                    <span class="text-xs text-cetus-ink-muted">
                      {challenge.currentValue}/{challenge.targetValue}
                    </span>
                  </div>
                )}
              </div>
              <div class="text-right">
                <span
                  class={`text-sm font-bold ${challenge.completed ? 'text-green-400' : 'text-cetus-accent'}`}
                >
                  +{challenge.xpReward} XP
                </span>
              </div>
            </div>
          </div>
        )
      })
    }
  </div>

  <!-- Streak Display -->
  {
    streak > 0 && (
      <div class="mt-6 pt-4 border-t border-cetus-hairline flex items-center gap-2">
        <span class="text-orange-400">🔥</span>
        <span class="text-sm text-cetus-ink-muted">
          Challenge Streak:{' '}
          <span class="text-orange-400 font-bold">{streak} days</span>
        </span>
      </div>
    )
  }
</Card>

<script>
  // Countdown timer
  const timerEl = document.getElementById('reset-timer')
  if (timerEl) {
    let seconds = parseInt(timerEl.dataset.resetIn || '0', 10)

    const showRefreshPrompt = () => {
      if (document.getElementById('mission-refresh-toast')) {
        return
      }
      const toast = document.createElement('div')
      toast.id = 'mission-refresh-toast'
      toast.className =
        'fixed bottom-6 right-6 z-50 max-w-sm rounded-xl bg-cetus-surface border border-cetus-hairline shadow-2xl shadow-cetus-accent/30 p-4 text-white backdrop-blur-md'
      toast.setAttribute('role', 'alert')
      toast.innerHTML = `
        <div class="flex items-start gap-3">
          <span class="text-xl">🔄</span>
          <div class="flex-1">
            <p class="font-semibold">Daily missions have reset</p>
            <p class="text-sm text-cetus-ink-muted mt-1">New daily missions are available. Refresh to load the latest set.</p>
            <div class="mt-3 flex gap-2">
              <button id="mission-refresh-now" class="px-3 py-1.5 rounded-lg bg-cetus-accent text-white text-sm font-semibold hover:bg-cetus-accent/90 focus:outline-none focus-visible:ring-2 focus-visible:ring-cetus-accent/50">Refresh now</button>
              <button id="mission-refresh-dismiss" class="px-3 py-1.5 rounded-lg border border-cetus-hairline text-sm text-cetus-ink-muted hover:border-cetus-accent/60 focus:outline-none focus-visible:ring-2 focus-visible:ring-cetus-accent/50">Dismiss</button>
            </div>
          </div>
        </div>
      `
      const refreshBtn = toast.querySelector<HTMLButtonElement>(
        '#mission-refresh-now'
      )
      const dismissBtn = toast.querySelector<HTMLButtonElement>(
        '#mission-refresh-dismiss'
      )
      refreshBtn?.addEventListener('click', () => window.location.reload())
      dismissBtn?.addEventListener('click', () => toast.remove())
      document.body.appendChild(toast)
    }

    function updateTimer() {
      const hours = Math.floor(seconds / 3600)
      const mins = Math.floor((seconds % 3600) / 60)
      const secs = seconds % 60
      if (timerEl) {
        timerEl.textContent = `Resets in ${hours.toString().padStart(2, '0')}:${mins.toString().padStart(2, '0')}:${secs.toString().padStart(2, '0')}`
      }

      if (seconds > 0) {
        seconds--
        setTimeout(updateTimer, 1000)
      } else {
        if (timerEl) {
          timerEl.textContent = 'Daily missions reset'
        }
        showRefreshPrompt()
      }
    }

    updateTimer()
  }
</script>
