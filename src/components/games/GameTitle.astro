---
interface Props {
  title: string
  description: string
  class?: string
}

const { title, description, class: className } = Astro.props
---

<!-- Game Title -->
<div class={`text-center mb-8 ${className || ''}`}>
  <h2 class="text-4xl md:text-5xl cetus-wordmark cetus-wordmark--glow mb-4">
    {title.toUpperCase()}
  </h2>
  <p class="text-cetus-ink-muted text-lg">
    {description}
  </p>
</div>
