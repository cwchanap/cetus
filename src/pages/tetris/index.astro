---
import GamePage from '@/components/games/GamePage.astro'
import Card from '@/components/ui/Card.astro'
import Badge from '@/components/ui/Badge.astro'
---

<GamePage
  gameId="tetris"
  title="Tetris Challenge"
  description="Stack the blocks and clear lines in this classic puzzle game with a futuristic twist"
  icon="🔲"
  showTime={false}
>
  <!-- Board mount point -->
  <div slot="game-board">
    <div
      id="tetris-container"
      class="border-2 border-cetus-hairline bg-black/50 rounded-lg"
      style="width: 300px; height: 600px;"
    >
    </div>
  </div>

  <!-- Additional stat badges (Level/Lines) rendered inside GameStats -->
  <Badge slot="additional-stats" variant="outline" class="px-4 py-2">
    <span class="font-mono">Level: <span id="level">1</span></span>
  </Badge>
  <Badge slot="additional-stats" variant="outline" class="px-4 py-2">
    <span class="font-mono">Lines: <span id="lines">0</span></span>
  </Badge>

  <!-- Sidebar: Next Piece, Controls, Statistics -->
  <div slot="game-info">
    <!-- Next Piece -->
    <Card variant="glass" class="p-6">
      <h3
        class="font-mono text-sm tracking-wide text-cetus-accent mb-4 text-center"
      >
        ▸ NEXT PIECE
      </h3>
      <canvas
        id="next-canvas"
        width="120"
        height="120"
        class="border border-cetus-hairline bg-black/30 rounded-lg mx-auto block"
      ></canvas>
    </Card>

    <!-- Controls Guide -->
    <Card variant="glass" class="p-6">
      <h3 class="font-mono text-sm tracking-wide text-cetus-accent mb-4">
        ▸ CONTROLS
      </h3>
      <div class="space-y-2 text-sm">
        <div class="flex justify-between">
          <span class="text-cetus-ink-muted">Move Left:</span>
          <Badge variant="outline" class="px-2 py-1 text-xs">←</Badge>
        </div>
        <div class="flex justify-between">
          <span class="text-cetus-ink-muted">Move Right:</span>
          <Badge variant="outline" class="px-2 py-1 text-xs">→</Badge>
        </div>
        <div class="flex justify-between">
          <span class="text-cetus-ink-muted">Soft Drop:</span>
          <Badge variant="outline" class="px-2 py-1 text-xs">↓</Badge>
        </div>
        <div class="flex justify-between">
          <span class="text-cetus-ink-muted">Hard Drop:</span>
          <Badge variant="outline" class="px-2 py-1 text-xs">Space</Badge>
        </div>
        <div class="flex justify-between">
          <span class="text-cetus-ink-muted">Rotate:</span>
          <Badge variant="outline" class="px-2 py-1 text-xs">↑</Badge>
        </div>
        <div class="flex justify-between">
          <span class="text-cetus-ink-muted">Pause:</span>
          <Badge variant="outline" class="px-2 py-1 text-xs">P</Badge>
        </div>
      </div>
    </Card>

    <!-- Statistics -->
    <Card variant="glass" class="p-6">
      <h3 class="font-mono text-sm tracking-wide text-cetus-accent mb-4">
        ▸ STATISTICS
      </h3>
      <div class="space-y-2 text-sm">
        <div class="flex justify-between">
          <span class="text-cetus-ink-muted">Pieces:</span>
          <span id="pieces-count" class="text-white">0</span>
        </div>
        <div class="flex justify-between">
          <span class="text-cetus-ink-muted">Singles:</span>
          <span id="singles-count" class="text-white">0</span>
        </div>
        <div class="flex justify-between">
          <span class="text-cetus-ink-muted">Doubles:</span>
          <span id="doubles-count" class="text-white">0</span>
        </div>
        <div class="flex justify-between">
          <span class="text-cetus-ink-muted">Triples:</span>
          <span id="triples-count" class="text-white">0</span>
        </div>
        <div class="flex justify-between">
          <span class="text-cetus-ink-muted">Tetrises:</span>
          <span id="tetrises-count" class="text-cetus-accent">0</span>
        </div>
      </div>
    </Card>
  </div>

  <!-- Custom overlay stats -->
  <div slot="final-stats">
    <div class="text-lg text-cetus-ink">
      Level Reached: <span id="final-level" class="text-cetus-accent">1</span>
    </div>
    <div class="text-lg text-cetus-ink">
      Lines Cleared: <span id="final-lines" class="text-cetus-accent">0</span>
    </div>
    <div class="text-lg text-cetus-ink">
      Pieces Placed: <span id="final-pieces" class="text-cetus-accent-3">0</span
      >
    </div>
    <div class="text-lg text-cetus-ink">
      Tetrises: <span id="final-tetrises" class="text-cetus-accent-2">0</span>
    </div>
  </div>
</GamePage>

<script>
  import { initTetrisGameFramework } from '@/lib/games/tetris/initFramework'

  // Initialize game when page loads. All button/keyboard wiring is
  // handled inside the framework initializer.
  document.addEventListener('DOMContentLoaded', async () => {
    try {
      const gameResult = await initTetrisGameFramework()

      if (!gameResult) {
        console.error('Failed to initialize Tetris game')
        return
      }

      // Expose game instance for debugging
      ;(window as Window & { tetrisGame?: typeof gameResult }).tetrisGame =
        gameResult
    } catch (error) {
      console.error('Failed to initialize Tetris game:', error)
    }
  })
</script>
