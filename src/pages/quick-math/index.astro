---
import GamePage from '@/components/games/GamePage.astro'
import Card from '@/components/ui/Card.astro'
import Badge from '@/components/ui/Badge.astro'
import Button from '@/components/ui/Button.astro'
---

<GamePage
  gameId="quick-math"
  title="Quick Math"
  description="Solve as many math problems as you can in 60 seconds!"
  icon="🧮"
  overlayTitle="TIME'S UP!"
  showPause={false}
  showReset={false}
>
  <!-- Board: question display + answer input -->
  <div slot="game-board" id="quick-math-container" class="p-8 w-full max-w-lg">
    <div class="flex flex-col items-center space-y-6">
      <!-- Question Display -->
      <div class="text-center mb-6">
        <div
          class="text-6xl font-bold text-white mb-4 min-h-20 flex items-center justify-center cetus-wordmark cetus-wordmark--glow"
          style="font-family: var(--cetus-display-font);"
        >
          <span id="question">Ready?</span>
        </div>
        <div class="text-lg text-cetus-ink-muted">What's the answer?</div>
      </div>

      <!-- Answer Input -->
      <div class="w-full max-w-xs">
        <input
          id="answer-input"
          type="text"
          class="w-full px-4 py-3 text-2xl font-mono text-center bg-black/50 border-2 border-cetus-hairline rounded-lg focus:border-cetus-accent focus:outline-none text-white placeholder-cetus-ink-muted disabled:opacity-50"
          placeholder="Enter answer"
          disabled
          autocomplete="off"
        />
      </div>

      <!-- Submit Button -->
      <Button id="submit-answer" variant="primary" size="lg" disabled>
        Submit Answer
      </Button>

      <!-- Current Session Stats -->
      <div class="flex space-x-6 text-sm mt-4">
        <div class="text-center">
          <div class="text-cetus-ink-muted">Questions</div>
          <div id="current-questions" class="text-white font-bold">0</div>
        </div>
        <div class="text-center">
          <div class="text-cetus-ink-muted">Correct</div>
          <div id="current-correct" class="text-green-400 font-bold">0</div>
        </div>
        <div class="text-center">
          <div class="text-cetus-ink-muted">Score</div>
          <div id="current-score" class="text-cetus-accent font-bold">0</div>
        </div>
      </div>
    </div>
  </div>

  <!-- Sidebar info -->
  <div slot="game-info">
    <!-- Game Rules -->
    <Card variant="glass" class="p-6">
      <h3 class="font-mono text-sm tracking-wide text-cetus-accent mb-4">
        ▸ GAME RULES
      </h3>
      <div class="space-y-3 text-sm text-cetus-ink">
        <div class="flex items-center space-x-2">
          <span class="text-green-400">✓</span>
          <span>Solve math problems as fast as you can</span>
        </div>
        <div class="flex items-center space-x-2">
          <span class="text-green-400">✓</span>
          <span>60 seconds to get the highest score</span>
        </div>
        <div class="flex items-center space-x-2">
          <span class="text-green-400">✓</span>
          <span>Each correct answer = 20 points</span>
        </div>
        <div class="flex items-center space-x-2">
          <span class="text-green-400">✓</span>
          <span>Numbers range from 1 to 999</span>
        </div>
        <div class="flex items-center space-x-2">
          <span class="text-green-400">✓</span>
          <span>Addition and subtraction only</span>
        </div>
      </div>
    </Card>

    <!-- Tips -->
    <Card variant="glass" class="p-6">
      <h3 class="font-mono text-sm tracking-wide text-cetus-accent mb-4">
        ▸ TIPS
      </h3>
      <div class="space-y-3 text-sm text-cetus-ink">
        <div class="flex items-start space-x-2">
          <span class="text-yellow-400 mt-0.5">💡</span>
          <span>Use mental math techniques for speed</span>
        </div>
        <div class="flex items-start space-x-2">
          <span class="text-yellow-400 mt-0.5">💡</span>
          <span>Press Enter to submit your answer quickly</span>
        </div>
        <div class="flex items-start space-x-2">
          <span class="text-yellow-400 mt-0.5">💡</span>
          <span>Don't worry about mistakes - speed matters!</span>
        </div>
        <div class="flex items-start space-x-2">
          <span class="text-yellow-400 mt-0.5">💡</span>
          <span>All subtraction results are positive</span>
        </div>
      </div>
    </Card>

    <!-- Controls -->
    <Card variant="glass" class="p-6">
      <h3 class="font-mono text-sm tracking-wide text-cetus-accent mb-4">
        ▸ CONTROLS
      </h3>
      <div class="space-y-4 text-sm">
        <div class="flex justify-between items-center">
          <span class="text-cetus-ink-muted">Submit Answer:</span>
          <Badge variant="outline" class="px-2 py-1 text-xs">Enter</Badge>
        </div>
        <div class="flex justify-between items-center">
          <span class="text-cetus-ink-muted">Numbers Only:</span>
          <Badge variant="outline" class="px-2 py-1 text-xs">0-9</Badge>
        </div>
        <div class="pt-2 border-t border-cetus-hairline">
          <div class="text-cetus-ink-muted text-xs">
            💡 Type your answer and press Enter for fastest gameplay
          </div>
        </div>
      </div>
    </Card>
  </div>

  <!-- Custom overlay stats -->
  <div slot="final-stats">
    <div class="text-lg text-cetus-ink">
      Questions Answered: <span id="total-questions" class="text-cetus-accent"
        >0</span
      >
    </div>
    <div class="text-lg text-cetus-ink">
      Accuracy: <span id="accuracy" class="text-green-400">0%</span>
    </div>
  </div>
</GamePage>

<script>
  import { initQuickMathFramework } from '@/lib/games/quick-math/init'

  // Initialize game when page loads
  document.addEventListener('DOMContentLoaded', async () => {
    try {
      const {
        game: _game,
        renderer: _renderer,
        cleanup,
      } = await initQuickMathFramework(
        {
          // Custom config if needed (all defaults are good)
        },
        {
          onEnd: async (_finalScore: number, _stats: unknown) => {
            // Additional custom handling if needed
            // Stats are already handled by framework
          },
        }
      )

      // Game is now fully initialized with framework
      // All button handlers are set up automatically by the framework
      // The game has proper start(), end(), reset() methods

      // Clean up on page unload
      window.addEventListener('beforeunload', () => {
        cleanup()
      })
    } catch (error) {
      console.error('Failed to initialize Quick Math game:', error)
      const questionEl = document.getElementById('question')
      if (questionEl) {
        questionEl.textContent = 'Failed to load game'
      }
      const inputEl = document.getElementById(
        'answer-input'
      ) as HTMLInputElement | null
      if (inputEl) {
        inputEl.placeholder = 'Game unavailable'
      }
      const submitBtn = document.getElementById(
        'submit-answer'
      ) as HTMLButtonElement | null
      if (submitBtn) {
        submitBtn.disabled = true
      }
    }
  })
</script>
