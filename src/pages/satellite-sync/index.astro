---
import GamePage from '@/components/games/GamePage.astro'
import Card from '@/components/ui/Card.astro'
---

<GamePage
  gameId="satellite-sync"
  title="Satellite Sync"
  description="Drag each satellite beam onto its matching target to lock on before the timer expires!"
  icon="🛰️"
  overlayTitle="MISSION COMPLETE!"
  overlayButtonText="Play Again"
>
  <!-- Board: canvas container + game-status + game-error -->
  <div slot="game-board">
    <div class="relative w-full">
      <div
        id="game-canvas-container"
        class="bg-black/30 rounded-lg min-w-[240px] min-h-[240px] w-full"
      >
      </div>

      <div
        id="game-status"
        class="absolute inset-0 flex items-center justify-center bg-black/70 rounded-lg"
      >
        <div class="text-center">
          <div class="text-6xl mb-4">🛰️</div>
          <div
            class="text-xl font-mono font-bold mb-2 cetus-wordmark cetus-wordmark--glow"
            style="font-family: var(--cetus-display-font);"
          >
            SATELLITE SYNC
          </div>
          <div class="text-cetus-ink-muted">
            Press Start to begin the mission!
          </div>
        </div>
      </div>

      <div
        id="game-error"
        class="hidden text-sm text-amber-400 bg-amber-950/40 border border-amber-700/50 rounded-md px-3 py-2 text-center"
      >
      </div>
    </div>
  </div>

  <!-- Additional stat badges (level / combo use game-specific IDs) -->
  <div slot="additional-stats" class="flex gap-4">
    <div
      class="font-mono text-cetus-accent border border-cetus-hairline rounded-lg px-4 py-2"
    >
      Level: <span id="level">1</span>
    </div>
    <div
      class="font-mono text-cetus-accent border border-cetus-hairline rounded-lg px-4 py-2"
    >
      Combo: <span id="combo">×1</span>
    </div>
  </div>

  <!-- Sidebar info -->
  <div slot="game-info">
    <!-- How to Play -->
    <Card variant="glass" class="p-6">
      <h3 class="font-mono text-sm tracking-wide text-cetus-accent mb-4">
        ▸ HOW TO PLAY
      </h3>
      <ul class="space-y-2 text-sm text-cetus-ink-muted">
        <li>• Drag a satellite to aim its beam</li>
        <li>• Release near a matching-color target to lock on</li>
        <li>• Asteroids block the beam — find a clear path</li>
        <li>• Lock targets quickly to build a combo multiplier</li>
        <li>• Clear every target before the timer hits zero</li>
      </ul>
    </Card>

    <!-- Scoring -->
    <Card variant="glass" class="p-6">
      <h3 class="font-mono text-sm tracking-wide text-cetus-accent mb-4">
        ▸ SCORING
      </h3>
      <div class="space-y-2 text-sm text-cetus-ink">
        <div class="flex justify-between">
          <span class="text-cetus-ink-muted">Lock:</span><span>100 × combo</span
          >
        </div>
        <div class="flex justify-between">
          <span class="text-cetus-ink-muted">Combo:</span><span
            >+0.5 per chain (max ×3)</span
          >
        </div>
        <div class="flex justify-between">
          <span class="text-cetus-ink-muted">Level clear:</span><span
            >250 × level</span
          >
        </div>
        <div class="flex justify-between">
          <span class="text-cetus-ink-muted">Time bonus:</span><span
            >×10 / sec left</span
          >
        </div>
      </div>
    </Card>
  </div>
</GamePage>

<script>
  import { initializeSatelliteSync } from '@/lib/games/satellite-sync/init'

  let gameHandle: Awaited<ReturnType<typeof initializeSatelliteSync>> | null =
    null

  const init = async () => {
    const container = document.getElementById('game-canvas-container')
    const statusEl = document.getElementById('game-status')
    const errorEl = document.getElementById('game-error')
    const overlay = document.getElementById('game-over-overlay')
    const startBtn = document.getElementById('start-btn')
    const endBtn = document.getElementById('end-btn')
    const playAgainBtn = document.getElementById('play-again-btn')
    const comboEl = document.getElementById('combo')
    if (
      !container ||
      !statusEl ||
      !errorEl ||
      !overlay ||
      !startBtn ||
      !endBtn ||
      !playAgainBtn ||
      !comboEl
    ) {
      return
    }

    const resetButtonState = () => {
      startBtn.style.display = 'inline-flex'
      endBtn.style.display = 'none'
    }

    const resetCombo = () => {
      comboEl.textContent = '×1'
    }

    try {
      gameHandle = await initializeSatelliteSync(container, {
        onGameStart: () => {
          statusEl.classList.add('hidden')
          errorEl.classList.add('hidden')
          overlay.classList.add('hidden')
          startBtn.style.display = 'none'
          endBtn.style.display = 'inline-flex'
          resetCombo()
        },
        onTimeUpdate: () => {},
        onScoreUpdate: () => {},
        onLock: info => {
          comboEl.textContent = `×${info.multiplier}`
        },
        onComboReset: () => {
          resetCombo()
        },
        onLevelClear: () => {
          resetCombo()
        },
        onFail: () => {
          resetButtonState()
          resetCombo()
        },
        onWin: () => {
          resetButtonState()
          resetCombo()
        },
        onError: (_title, message) => {
          errorEl.textContent = message
          errorEl.classList.remove('hidden')
        },
      })

      startBtn.addEventListener('click', async () => {
        startBtn.style.display = 'none'
        try {
          if (!gameHandle) {
            return
          }
          await gameHandle.start()
        } catch (error) {
          errorEl.textContent =
            error instanceof Error
              ? error.message
              : 'Failed to start the game. Please try again.'
          errorEl.classList.remove('hidden')
          resetButtonState()
        }
      })

      endBtn.addEventListener('click', () => {
        gameHandle?.stop()
        statusEl.classList.remove('hidden')
        resetButtonState()
        resetCombo()
      })

      playAgainBtn.addEventListener('click', () => {
        overlay.classList.add('hidden')
        errorEl.classList.add('hidden')
        statusEl.classList.remove('hidden')
        resetButtonState()
      })
    } catch (error) {
      errorEl.textContent =
        error instanceof Error
          ? error.message
          : 'Failed to initialize the game. Please refresh the page.'
      errorEl.classList.remove('hidden')
      resetButtonState()
    }
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', init)
  } else {
    init()
  }

  window.addEventListener('beforeunload', () => {
    gameHandle?.cleanup()
  })
</script>
