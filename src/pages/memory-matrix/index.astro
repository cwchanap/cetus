---
import GamePage from '@/components/games/GamePage.astro'
import Card from '@/components/ui/Card.astro'
import Badge from '@/components/ui/Badge.astro'
---

<GamePage
  gameId="memory-matrix"
  title="Memory Matrix"
  description="Test your memory by matching pairs of shapes in this grid-based puzzle game"
  icon="🧠"
>
  <!-- Board mount -->
  <div slot="game-board">
    <div
      id="memory-matrix-container"
      class="border-2 border-cetus-hairline bg-black/50 rounded-lg"
      style="width: 640px; height: 480px;"
    >
      <div
        id="memory-board"
        class="w-full h-full grid grid-cols-8 grid-rows-6 gap-2 p-2"
      >
      </div>
    </div>
  </div>

  <!-- Additional stat badges (game-score / game-time / pairs use game-specific IDs) -->
  <Badge slot="additional-stats" variant="outline" class="px-4 py-2">
    <span class="font-mono">Score: <span id="game-score">0</span></span>
  </Badge>
  <Badge slot="additional-stats" variant="outline" class="px-4 py-2">
    <span class="font-mono">Time: <span id="game-time">1:00</span></span>
  </Badge>
  <Badge slot="additional-stats" variant="outline" class="px-4 py-2">
    <span class="font-mono">Pairs: <span id="game-pairs">0/24</span></span>
  </Badge>

  <!-- Sidebar -->
  <div slot="game-info">
    <!-- Game Rules -->
    <Card variant="glass" class="p-6">
      <h3 class="font-mono text-sm tracking-wide text-cetus-accent mb-4">
        ▸ HOW TO PLAY
      </h3>
      <div class="space-y-2 text-sm text-cetus-ink-muted">
        <p>• Click on cards to flip them over</p>
        <p>• Find matching pairs of shapes</p>
        <p>• Match all pairs before time runs out</p>
        <p>• Faster matches = higher score</p>
        <p>• You have 60 seconds to complete the grid</p>
      </div>
    </Card>

    <!-- Game Statistics -->
    <Card variant="glass" class="p-6">
      <h3 class="font-mono text-sm tracking-wide text-cetus-accent mb-4">
        ▸ STATISTICS
      </h3>
      <div class="space-y-2 text-sm">
        <div class="flex justify-between">
          <span class="text-cetus-ink-muted">Accuracy:</span>
          <span id="game-accuracy" class="text-white">0%</span>
        </div>
        <div class="flex justify-between">
          <span class="text-cetus-ink-muted">Pairs Found:</span>
          <span id="pairs-found" class="text-green-400">0</span>
        </div>
        <div class="flex justify-between">
          <span class="text-cetus-ink-muted">Total Attempts:</span>
          <span id="total-attempts" class="text-white">0</span>
        </div>
      </div>
    </Card>

    <!-- Scoring System -->
    <Card variant="glass" class="p-6">
      <h3 class="font-mono text-sm tracking-wide text-cetus-accent mb-4">
        ▸ SCORING
      </h3>
      <div class="space-y-2 text-sm">
        <div class="flex justify-between">
          <span class="text-cetus-ink-muted">Per Match:</span>
          <span class="text-green-400">+100 points</span>
        </div>
        <div class="flex justify-between">
          <span class="text-cetus-ink-muted">Time Bonus:</span>
          <span class="text-yellow-400">+5 per second left</span>
        </div>
        <div class="flex justify-between">
          <span class="text-cetus-ink-muted">Total Pairs:</span>
          <span class="text-white">24 pairs</span>
        </div>
        <div class="flex justify-between">
          <span class="text-cetus-ink-muted">Maximum Score:</span>
          <span class="text-cetus-accent">2,700 points</span>
        </div>
      </div>
    </Card>

    <!-- Game Shapes Preview -->
    <Card variant="glass" class="p-6">
      <h3 class="font-mono text-sm tracking-wide text-cetus-accent mb-4">
        ▸ SHAPES
      </h3>
      <div class="grid grid-cols-4 gap-2">
        <div class="text-2xl text-center p-2 bg-black/30 rounded">🔵</div>
        <div class="text-2xl text-center p-2 bg-black/30 rounded">🔺</div>
        <div class="text-2xl text-center p-2 bg-black/30 rounded">🔶</div>
        <div class="text-2xl text-center p-2 bg-black/30 rounded">⭐</div>
        <div class="text-2xl text-center p-2 bg-black/30 rounded">❤️</div>
        <div class="text-2xl text-center p-2 bg-black/30 rounded">🟢</div>
        <div class="text-2xl text-center p-2 bg-black/30 rounded">🔴</div>
        <div class="text-2xl text-center p-2 bg-black/30 rounded">🟡</div>
      </div>
      <p class="text-xs text-cetus-ink-muted mt-2 text-center">
        Each shape appears 6 times (3 pairs each)
      </p>
    </Card>
  </div>

  <!-- Custom overlay stats -->
  <div slot="final-stats">
    <div class="text-lg text-cetus-ink">
      Pairs Found: <span id="final-pairs" class="text-green-400">0/24</span>
    </div>
    <div class="text-lg text-cetus-ink">
      Accuracy: <span id="final-accuracy" class="text-cetus-accent">0%</span>
    </div>
    <div class="text-lg text-cetus-ink">
      Time Remaining: <span id="final-time" class="text-purple-400">0s</span>
    </div>
    <div class="text-lg text-cetus-ink">
      Total Attempts: <span id="final-attempts" class="text-yellow-400">0</span>
    </div>
  </div>
</GamePage>

<script>
  import { initMemoryMatrixGameFramework } from '@/lib/games/memory-matrix/initFramework'

  // Initialize game when page loads. All button/card wiring is handled
  // inside the framework initializer.
  document.addEventListener('DOMContentLoaded', async () => {
    try {
      const gameInstance = await initMemoryMatrixGameFramework()

      if (!gameInstance) {
        console.error('Failed to initialize Memory Matrix game')
        return
      }

      // Expose game instance for debugging
      ;(
        window as Window & {
          memoryMatrixGame?: typeof gameInstance
        }
      ).memoryMatrixGame = gameInstance
    } catch (error) {
      console.error('Failed to initialize Memory Matrix game:', error)
    }
  })
</script>
