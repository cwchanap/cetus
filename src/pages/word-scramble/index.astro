---
import GamePage from '@/components/games/GamePage.astro'
import Card from '@/components/ui/Card.astro'
import Badge from '@/components/ui/Badge.astro'
import Button from '@/components/ui/Button.astro'
---

<GamePage
  gameId="word-scramble"
  title="Word Scramble"
  description="Unscramble words as fast as you can in 60 seconds!"
  icon="🔤"
  overlayTitle="TIME'S UP!"
>
  <!-- Board: scrambled word + answer input -->
  <div slot="game-board" class="p-8 w-full max-w-lg">
    <div class="flex flex-col items-center space-y-6">
      <!-- Scrambled Word Display -->
      <div class="text-center mb-6">
        <div class="text-lg text-cetus-ink-muted mb-2">
          Unscramble this word:
        </div>
        <div
          class="text-6xl font-bold text-white mb-4 min-h-20 flex items-center justify-center cetus-wordmark cetus-wordmark--glow"
          style="font-family: var(--cetus-display-font);"
        >
          <span id="scrambled-word">READY?</span>
        </div>
        <div class="text-sm text-cetus-ink-muted">
          <span id="word-difficulty" class="px-2 py-1 rounded bg-slate-800"
          ></span>
        </div>
      </div>

      <!-- Answer Input -->
      <div class="w-full max-w-xs">
        <input
          id="answer-input"
          type="text"
          class="w-full px-4 py-3 text-2xl font-mono text-center bg-black/50 border-2 border-cetus-hairline rounded-lg focus:border-cetus-accent focus:outline-none text-white placeholder-cetus-ink-muted disabled:opacity-50 transition-colors"
          placeholder="Your answer"
          disabled
          autocomplete="off"
        />
      </div>

      <!-- Submit / Skip Buttons -->
      <div class="flex space-x-3">
        <Button id="submit-answer" variant="primary" size="lg" disabled>
          Submit Answer
        </Button>
        <Button id="skip-word" variant="outline" size="lg" disabled>
          Skip Word
        </Button>
      </div>

      <!-- Current Session Stats -->
      <div class="flex space-x-6 text-sm mt-4">
        <div class="text-center">
          <div class="text-cetus-ink-muted">Words</div>
          <div id="current-words" class="text-white font-bold">0</div>
        </div>
        <div class="text-center">
          <div class="text-cetus-ink-muted">Correct</div>
          <div id="current-correct" class="text-green-400 font-bold">0</div>
        </div>
        <div class="text-center">
          <div class="text-cetus-ink-muted">Score</div>
          <div id="current-score" class="text-cetus-accent font-bold">0</div>
        </div>
      </div>
    </div>
  </div>

  <!-- Sidebar info -->
  <div slot="game-info">
    <!-- Game Rules -->
    <Card variant="glass" class="p-6">
      <h3 class="font-mono text-sm tracking-wide text-cetus-accent mb-4">
        ▸ GAME RULES
      </h3>
      <div class="space-y-3 text-sm text-cetus-ink">
        <div class="flex items-center space-x-2">
          <span class="text-green-400">✓</span>
          <span>Unscramble words as fast as you can</span>
        </div>
        <div class="flex items-center space-x-2">
          <span class="text-green-400">✓</span>
          <span>60 seconds to achieve the highest score</span>
        </div>
        <div class="flex items-center space-x-2">
          <span class="text-green-400">✓</span>
          <span>Easy words = 40 points, Medium = 20, Hard = 30</span>
        </div>
        <div class="flex items-center space-x-2">
          <span class="text-green-400">✓</span>
          <span>Quick answers earn bonus points</span>
        </div>
        <div class="flex items-center space-x-2">
          <span class="text-green-400">✓</span>
          <span>Skip words if you're stuck</span>
        </div>
      </div>
    </Card>

    <!-- Scoring System -->
    <Card variant="glass" class="p-6">
      <h3 class="font-mono text-sm tracking-wide text-cetus-accent mb-4">
        ▸ SCORING
      </h3>
      <div class="space-y-3 text-sm text-cetus-ink">
        <div class="flex justify-between items-center">
          <span class="text-green-400">Easy Words (3-4 letters):</span>
          <span class="font-bold">10 pts</span>
        </div>
        <div class="flex justify-between items-center">
          <span class="text-yellow-400">Medium Words (5-6 letters):</span>
          <span class="font-bold">20 pts</span>
        </div>
        <div class="flex justify-between items-center">
          <span class="text-red-400">Hard Words (7+ letters):</span>
          <span class="font-bold">30 pts</span>
        </div>
        <div class="border-t border-cetus-hairline pt-3 mt-3">
          <div class="text-cetus-ink-muted text-xs mb-2">Speed Bonuses:</div>
          <div class="flex justify-between items-center">
            <span class="text-cetus-accent">Under 3 seconds:</span>
            <span class="font-bold">+10 pts</span>
          </div>
          <div class="flex justify-between items-center">
            <span class="text-cetus-accent">Under 5 seconds:</span>
            <span class="font-bold">+5 pts</span>
          </div>
        </div>
      </div>
    </Card>

    <!-- Controls -->
    <Card variant="glass" class="p-6">
      <h3 class="font-mono text-sm tracking-wide text-cetus-accent mb-4">
        ▸ CONTROLS
      </h3>
      <div class="space-y-4 text-sm">
        <div class="flex justify-between items-center">
          <span class="text-cetus-ink-muted">Submit Answer:</span>
          <Badge variant="outline" class="px-2 py-1 text-xs">Enter</Badge>
        </div>
        <div class="flex justify-between items-center">
          <span class="text-cetus-ink-muted">Skip Word:</span>
          <Badge variant="outline" class="px-2 py-1 text-xs">Button</Badge>
        </div>
        <div class="flex justify-between items-center">
          <span class="text-cetus-ink-muted">Letters Only:</span>
          <Badge variant="outline" class="px-2 py-1 text-xs">A-Z</Badge>
        </div>
        <div class="pt-2 border-t border-cetus-hairline">
          <div class="text-cetus-ink-muted text-xs">
            💡 Type your answer and press Enter for fastest gameplay
          </div>
        </div>
      </div>
    </Card>
  </div>

  <!-- Custom overlay stats -->
  <div slot="final-stats">
    <div class="text-lg text-cetus-ink">
      Words Attempted: <span id="total-words" class="text-cetus-accent">0</span>
    </div>
    <div class="text-lg text-cetus-ink">
      Accuracy: <span id="accuracy" class="text-green-400">0%</span>
    </div>
    <div class="text-lg text-cetus-ink">
      Longest Word: <span id="longest-word" class="text-purple-400">None</span>
    </div>
  </div>

  <!-- Init script -->
  <script slot="game-script">
    import { initWordScrambleGameFramework } from '@/lib/games/word-scramble/initFramework'

    // Initialize game when page loads. All button/keyboard wiring is
    // handled inside the framework initializer.
    document.addEventListener('DOMContentLoaded', async () => {
      try {
        await initWordScrambleGameFramework()
      } catch (error) {
        console.error('Failed to initialize Word Scramble game:', error)
      }
    })
  </script>
</GamePage>
