---
import GamePage from '@/components/games/GamePage.astro'
import Card from '@/components/ui/Card.astro'
---

<GamePage
  gameId="bejeweled"
  title="Bejeweled"
  description="Swap adjacent gems to make matches and rack up points before time runs out"
  icon="💎"
  overlayTitle="TIME UP"
>
  <!-- Board: bejeweled canvas container -->
  <div slot="game-board">
    <div
      id="bejeweled-container"
      class="border-2 border-cetus-hairline bg-black/50 rounded-lg"
      style="width: 480px; height: 480px;"
    >
    </div>
  </div>

  <!-- Sidebar -->
  <div slot="game-info">
    <!-- How to Play -->
    <Card variant="glass" class="p-6">
      <h3 class="font-mono text-sm tracking-wide text-cetus-accent mb-4">
        ▸ HOW TO PLAY
      </h3>
      <div class="space-y-2 text-sm text-cetus-ink">
        <p>• Click two adjacent gems to swap them.</p>
        <p>• Form a line of 3 or more matching gems to score.</p>
        <p>• Matches may cascade for combo points.</p>
        <p>• You have 60 seconds—maximize your score!</p>
      </div>
    </Card>
  </div>

  <!-- Init script -->
  <script slot="game-script">
    import {
      initBejeweledGame,
      type BejeweledInitResult,
    } from '@/lib/games/bejeweled/init'

    document.addEventListener('DOMContentLoaded', async () => {
      try {
        const _result: BejeweledInitResult | undefined =
          await initBejeweledGame()

        // Wire restart button (overlay) just in case
        document
          .getElementById('play-again-btn')
          ?.addEventListener('click', () => {
            // Overlay handled in init, game.reset() is called there
          })
      } catch (error) {
        console.error('Failed to initialize Bejeweled game:', error)
      }
    })
  </script>
</GamePage>
