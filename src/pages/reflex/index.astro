---
import GamePage from '@/components/games/GamePage.astro'
import Card from '@/components/ui/Card.astro'
import Badge from '@/components/ui/Badge.astro'
import Button from '@/components/ui/Button.astro'
---

<GamePage
  gameId="reflex"
  title="Reflex Coin Collection"
  description="Click coins to score points, avoid bombs! React fast in 60 seconds!"
  icon="⚡"
  overlayTitle="TIME'S UP!"
  overlayButtonText="Close"
>
  <!-- Board: canvas container + game-status overlay -->
  <div slot="game-board">
    <div class="relative">
      <div id="game-canvas-container" class="bg-black/30 rounded-lg"></div>

      <!-- Game Status Message -->
      <div
        id="game-status"
        class="hidden absolute inset-0 items-center justify-center bg-black/70 rounded-lg"
      >
        <div class="text-center">
          <div class="text-6xl mb-4">⚡</div>
          <div
            class="text-xl font-mono font-bold mb-2 cetus-wordmark cetus-wordmark--glow"
            style="font-family: var(--cetus-display-font);"
          >
            REFLEX TEST
          </div>
          <div class="text-cetus-ink-muted">
            Click the button below to start!
          </div>
        </div>
      </div>

      <!-- Pre-rendered error state (safe textContent updates) -->
      <div
        id="game-error"
        class="hidden absolute inset-0 items-center justify-center bg-black/70 rounded-lg"
      >
        <div class="text-center">
          <div class="text-cetus-accent-3 text-xl mb-2">
            Failed to Load Game
          </div>
          <div id="game-error-message" class="text-cetus-ink-muted text-sm">
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Custom controls (uses stop-btn, not end-btn) -->
  <div slot="controls">
    <Card variant="glass" class="p-6">
      <div class="flex flex-col items-center space-y-4">
        <div class="flex space-x-3">
          <Button id="start-btn" variant="primary">Start Game</Button>
          <Button id="stop-btn" variant="outline" style="display: none;"
            >End Game</Button
          >
        </div>
      </div>
    </Card>
  </div>

  <!-- Sidebar info -->
  <div slot="game-info">
    <!-- Current Session Stats -->
    <Card variant="glass" class="p-6">
      <h3 class="font-mono text-sm tracking-wide text-cetus-accent mb-4">
        ▸ SESSION
      </h3>
      <div class="flex justify-center space-x-6 text-sm">
        <div class="text-center">
          <div class="text-cetus-ink-muted">Coins</div>
          <div id="coins-collected" class="text-cetus-accent font-bold">0</div>
        </div>
        <div class="text-center">
          <div class="text-cetus-ink-muted">Bombs Hit</div>
          <div id="bombs-hit" class="text-cetus-accent-3 font-bold">0</div>
        </div>
        <div class="text-center">
          <div class="text-cetus-ink-muted">Accuracy</div>
          <div id="accuracy" class="text-cetus-accent font-bold">0%</div>
        </div>
      </div>
    </Card>

    <!-- Game Rules -->
    <Card variant="glass" class="p-6">
      <h3 class="font-mono text-sm tracking-wide text-cetus-accent mb-4">
        ▸ GAME RULES
      </h3>
      <div class="space-y-3 text-sm text-cetus-ink">
        <div class="flex items-center space-x-2">
          <span class="text-cetus-accent">✓</span>
          <span>Click gold coins to earn +10 points</span>
        </div>
        <div class="flex items-center space-x-2">
          <span class="text-cetus-accent-3">✗</span>
          <span>Avoid red bombs (-15 points)</span>
        </div>
        <div class="flex items-center space-x-2">
          <span class="text-cetus-accent-2">⚠</span>
          <span>Missed coins cost -5 points</span>
        </div>
        <div class="flex items-center space-x-2">
          <span class="text-cetus-accent">⏱</span>
          <span>Objects appear for 2 seconds</span>
        </div>
        <div class="flex items-center space-x-2">
          <span class="text-cetus-accent-3">📊</span>
          <span>2:1 coin to bomb ratio</span>
        </div>
      </div>
    </Card>

    <!-- Scoring System -->
    <Card variant="glass" class="p-6">
      <h3 class="font-mono text-sm tracking-wide text-cetus-accent mb-4">
        ▸ SCORING
      </h3>
      <div class="space-y-3 text-sm text-cetus-ink">
        <div class="flex justify-between items-center">
          <span class="text-cetus-accent">Collect Coin:</span>
          <span class="font-bold">+10 pts</span>
        </div>
        <div class="flex justify-between items-center">
          <span class="text-cetus-accent-3">Hit Bomb:</span>
          <span class="font-bold">-15 pts</span>
        </div>
        <div class="flex justify-between items-center">
          <span class="text-cetus-accent-2">Miss Coin:</span>
          <span class="font-bold">-5 pts</span>
        </div>
        <div class="border-t border-cetus-hairline pt-3 mt-3">
          <div class="text-cetus-ink-muted text-xs mb-2">Strategy Tips:</div>
          <div class="text-xs space-y-1">
            <div>• Focus on accuracy over speed</div>
            <div>• Watch for bomb patterns</div>
            <div>• React quickly to maximize score</div>
          </div>
        </div>
      </div>
    </Card>

    <!-- Controls -->
    <Card variant="glass" class="p-6">
      <h3 class="font-mono text-sm tracking-wide text-cetus-accent mb-4">
        ▸ CONTROLS
      </h3>
      <div class="space-y-4 text-sm">
        <div class="flex justify-between items-center">
          <span class="text-cetus-ink-muted">Click Objects:</span>
          <Badge variant="outline" class="px-2 py-1 text-xs">Mouse</Badge>
        </div>
        <div class="flex justify-between items-center">
          <span class="text-cetus-ink-muted">Start Game:</span>
          <Badge variant="outline" class="px-2 py-1 text-xs">Button</Badge>
        </div>
        <div class="flex justify-between items-center">
          <span class="text-cetus-ink-muted">Grid Size:</span>
          <Badge variant="outline" class="px-2 py-1 text-xs">12×12</Badge>
        </div>
      </div>
    </Card>
  </div>

  <!-- Custom overlay stats -->
  <div slot="final-stats">
    <div class="text-lg text-cetus-ink">
      Coins Collected: <span id="final-coins" class="text-cetus-accent">0</span>
    </div>
    <div class="text-lg text-cetus-ink">
      Bombs Hit: <span id="final-bombs" class="text-cetus-accent-3">0</span>
    </div>
    <div class="text-lg text-cetus-ink">
      Accuracy: <span id="final-accuracy" class="text-cetus-accent">0%</span>
    </div>
    <div class="text-lg text-cetus-ink">
      Avg Reaction: <span id="avg-reaction" class="text-cetus-accent-3"
        >0ms</span
      >
    </div>
  </div>
</GamePage>

<script>
  import { initReflexGameFramework } from '@/lib/games/reflex/initFramework'

  let gameInstance: Awaited<ReturnType<typeof initReflexGameFramework>> | null =
    null

  // Initialize game when page loads
  document.addEventListener('DOMContentLoaded', async () => {
    try {
      gameInstance = await initReflexGameFramework()

      if (!gameInstance) {
        throw new Error('Failed to initialize game framework')
      }
    } catch (error) {
      console.error('Failed to initialize Reflex game:', error)
      const errorContainer = document.getElementById('game-error')
      const errorMessage = document.getElementById('game-error-message')
      if (errorMessage) {
        errorMessage.textContent = String(error)
      }
      if (errorContainer) {
        errorContainer.style.display = 'flex'
      }
    }
  })

  // Cleanup on page unload
  window.addEventListener('beforeunload', () => {
    if (gameInstance) {
      gameInstance.cleanup()
    }
  })
</script>
