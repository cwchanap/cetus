---
import GamePage from '@/components/games/GamePage.astro'
import Card from '@/components/ui/Card.astro'
import Badge from '@/components/ui/Badge.astro'
import Button from '@/components/ui/Button.astro'
---

<GamePage
  gameId="sudoku"
  title="Sudoku Challenge"
  description="Fill the grid so each row, column, and 3x3 box contains digits 1-9"
  icon="🔢"
>
  <!-- Board: sudoku grid -->
  <div slot="game-board">
    <div
      id="sudoku-container"
      class="border-2 border-cetus-hairline bg-black/50 rounded-lg"
      style="width: 450px; height: 450px;"
    >
    </div>
  </div>

  <!-- Additional stat badges (game-time / difficulty use game-specific IDs) -->
  <Badge slot="additional-stats" variant="outline" class="px-4 py-2">
    <span class="font-mono">Time: <span id="game-time">00:00</span></span>
  </Badge>
  <Badge slot="additional-stats" variant="outline" class="px-4 py-2">
    <span class="font-mono"
      >Difficulty: <span id="difficulty">Medium</span></span
    >
  </Badge>

  <!-- Sidebar -->
  <div slot="game-info">
    <!-- Difficulty Settings -->
    <Card variant="glass" class="p-6">
      <h3 class="font-mono text-sm tracking-wide text-purple-400 mb-4">
        ▸ DIFFICULTY
      </h3>
      <div class="space-y-3">
        <Button id="easy-btn" class="w-full justify-start">
          <span class="mr-2">🟢</span>
          Easy (40 clues)
        </Button>
        <Button id="medium-btn" class="w-full justify-start">
          <span class="mr-2">🟡</span>
          Medium (30 clues)
        </Button>
        <Button id="hard-btn" class="w-full justify-start">
          <span class="mr-2">🔴</span>
          Hard (20 clues)
        </Button>
      </div>
    </Card>

    <!-- Controls Guide -->
    <Card variant="glass" class="p-6">
      <h3 class="font-mono text-sm tracking-wide text-cetus-accent mb-4">
        ▸ CONTROLS
      </h3>
      <div class="space-y-2 text-sm">
        <div class="flex justify-between">
          <span class="text-cetus-ink-muted">Select Cell:</span>
          <Badge variant="outline" class="px-2 py-1 text-xs">Click</Badge>
        </div>
        <div class="flex justify-between">
          <span class="text-cetus-ink-muted">Enter Number:</span>
          <Badge variant="outline" class="px-2 py-1 text-xs">1-9</Badge>
        </div>
        <div class="flex justify-between">
          <span class="text-cetus-ink-muted">Clear Cell:</span>
          <Badge variant="outline" class="px-2 py-1 text-xs">Delete</Badge>
        </div>
        <div class="flex justify-between">
          <span class="text-cetus-ink-muted">Navigate:</span>
          <Badge variant="outline" class="px-2 py-1 text-xs">Arrow Keys</Badge>
        </div>
        <div class="flex justify-between">
          <span class="text-cetus-ink-muted">Pause:</span>
          <Badge variant="outline" class="px-2 py-1 text-xs">P</Badge>
        </div>
      </div>
    </Card>

    <!-- How to Play -->
    <Card variant="glass" class="p-6">
      <h3 class="font-mono text-sm tracking-wide text-cetus-accent mb-4">
        ▸ HOW TO PLAY
      </h3>
      <div class="space-y-2 text-sm text-cetus-ink">
        <p>• Click on any empty cell to select it</p>
        <p>• Type numbers 1-9 to fill cells</p>
        <p>• Each row, column, and 3×3 box must contain all digits 1-9</p>
        <p>• Use Delete/Backspace to clear cells</p>
      </div>
    </Card>
  </div>

  <!-- Custom overlay stats -->
  <div slot="final-stats">
    <div class="text-lg text-cetus-ink">
      Time Played: <span id="final-time" class="text-cetus-accent">00:00</span>
    </div>
    <div class="text-lg text-cetus-ink">
      Final Score: <span id="final-score" class="text-green-400">0</span>
    </div>
    <div class="text-lg text-cetus-ink">
      Difficulty: <span id="final-difficulty" class="text-purple-400"
        >Medium</span
      >
    </div>
  </div>
</GamePage>

<script>
  import { initSudokuGameFramework } from '@/lib/games/sudoku/initFramework'

  // Initialize game when page loads. All button/keyboard/difficulty wiring
  // is handled inside the framework initializer.
  document.addEventListener('DOMContentLoaded', async () => {
    try {
      const gameInstance = await initSudokuGameFramework()

      if (!gameInstance) {
        console.error('Failed to initialize Sudoku game')
        return
      }

      // Expose game instance for debugging
      ;(window as any).sudokuGame = gameInstance
    } catch (error) {
      console.error('Failed to initialize Sudoku game:', error)
    }
  })
</script>
