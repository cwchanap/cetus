---
import GamePage from '@/components/games/GamePage.astro'
import Card from '@/components/ui/Card.astro'
import Badge from '@/components/ui/Badge.astro'
---

<GamePage
  gameId="snake"
  title="Snake"
  description="Grow your snake by eating food - survive for 60 seconds!"
  icon="🐍"
>
  <!-- Board: snake canvas container -->
  <div slot="game-board">
    <div
      id="snake-container"
      class="border-2 border-cetus-hairline bg-black/50 rounded-lg"
      style="width: 500px; height: 500px;"
    >
    </div>
  </div>

  <!-- Additional stat: snake length -->
  <Badge slot="additional-stats" variant="outline" class="px-4 py-2">
    <span class="font-mono">Length: <span id="snake-length">3</span></span>
  </Badge>

  <!-- Sidebar -->
  <div slot="game-info">
    <!-- Controls Guide -->
    <Card variant="glass" class="p-6">
      <h3 class="font-mono text-sm tracking-wide text-cetus-accent mb-4">
        ▸ CONTROLS
      </h3>
      <div class="space-y-2 text-sm">
        <div class="flex justify-between">
          <span class="text-cetus-ink-muted">Move Up:</span>
          <Badge variant="outline" class="px-2 py-1 text-xs">↑ / W</Badge>
        </div>
        <div class="flex justify-between">
          <span class="text-cetus-ink-muted">Move Down:</span>
          <Badge variant="outline" class="px-2 py-1 text-xs">↓ / S</Badge>
        </div>
        <div class="flex justify-between">
          <span class="text-cetus-ink-muted">Move Left:</span>
          <Badge variant="outline" class="px-2 py-1 text-xs">← / A</Badge>
        </div>
        <div class="flex justify-between">
          <span class="text-cetus-ink-muted">Move Right:</span>
          <Badge variant="outline" class="px-2 py-1 text-xs">→ / D</Badge>
        </div>
        <div class="flex justify-between">
          <span class="text-cetus-ink-muted">Pause:</span>
          <Badge variant="outline" class="px-2 py-1 text-xs">P</Badge>
        </div>
      </div>
    </Card>

    <!-- Game Info -->
    <Card variant="glass" class="p-6">
      <h3 class="font-mono text-sm tracking-wide text-cetus-accent mb-4">
        ▸ GAME INFO
      </h3>
      <div class="space-y-2 text-sm">
        <div class="flex justify-between">
          <span class="text-cetus-ink-muted">Duration:</span>
          <span class="text-white">60 seconds</span>
        </div>
        <div class="flex justify-between">
          <span class="text-cetus-ink-muted">Food Spawn:</span>
          <span class="text-white">Every 1s</span>
        </div>
        <div class="flex justify-between">
          <span class="text-cetus-ink-muted">Points per Food:</span>
          <span class="text-white">10</span>
        </div>
      </div>
    </Card>

    <!-- Statistics -->
    <Card variant="glass" class="p-6">
      <h3 class="font-mono text-sm tracking-wide text-cetus-accent mb-4">
        ▸ STATISTICS
      </h3>
      <div class="space-y-2 text-sm">
        <div class="flex justify-between">
          <span class="text-cetus-ink-muted">Foods Eaten:</span>
          <span id="foods-eaten" class="text-white">0</span>
        </div>
        <div class="flex justify-between">
          <span class="text-cetus-ink-muted">Current Length:</span>
          <span id="snake-length-stats" class="text-cetus-accent">3</span>
        </div>
      </div>
    </Card>

    <!-- How to Play -->
    <Card variant="glass" class="p-6">
      <h3 class="font-mono text-sm tracking-wide text-cetus-accent mb-4">
        ▸ HOW TO PLAY
      </h3>
      <ul class="space-y-2 text-sm text-cetus-ink-muted">
        <li>• Use arrow keys or WASD to move</li>
        <li>• Eat food to grow longer</li>
        <li>• Don't hit walls or yourself</li>
        <li>• Survive for 60 seconds</li>
        <li>• +10 points per food eaten</li>
      </ul>
    </Card>
  </div>

  <!-- Custom overlay stats -->
  <div slot="final-stats">
    <div class="text-lg text-cetus-ink">
      Max Length: <span id="final-length" class="text-cetus-accent">3</span>
    </div>
    <div class="text-lg text-cetus-ink">
      Foods Eaten: <span id="final-foods" class="text-green-400">0</span>
    </div>
    <div class="text-lg text-cetus-ink">
      Time Survived: <span id="final-time" class="text-purple-400">0s</span>
    </div>
  </div>
</GamePage>

<script>
  import { initSnakeGameFramework } from '@/lib/games/snake/initFramework'

  // Initialize game when page loads
  document.addEventListener('DOMContentLoaded', async () => {
    try {
      const gameResult = await initSnakeGameFramework()

      if (!gameResult) {
        // eslint-disable-next-line no-console
        console.error(
          'Failed to initialize Snake game: initialization returned no game instance'
        )
        return
      }

      // Expose for debugging
      ;(window as Window & { snakeGame?: typeof gameResult }).snakeGame =
        gameResult
    } catch (error) {
      // eslint-disable-next-line no-console
      console.error('Failed to initialize Snake game:', error)
    }
  })
</script>
