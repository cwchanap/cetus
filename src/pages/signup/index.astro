---
import AppLayout from '@/layouts/AppLayout.astro'
import Card from '@/components/ui/Card.astro'
import Section from '@/components/ui/Section.astro'
import Container from '@/components/ui/Container.astro'
import Heading from '@/components/ui/Heading.astro'
---

<AppLayout
  title="Sign Up - Cetus Gaming Platform"
  description="Create your Cetus account to track your gaming progress and compete with friends"
>
  <!-- Sign Up Section -->
  <Section>
    <Container class="max-w-md">
      <div class="text-center mb-8">
        <Heading
          level={2}
          variant="section"
          align="center"
          kicker="AUTH · SIGNUP"
          class="mb-4"
        >
          CREATE ACCOUNT
        </Heading>
        <p class="text-cetus-ink-muted text-lg">
          Join Cetus with your Google account
        </p>
      </div>

      <Card variant="glass" brackets class="p-8">
        <div class="space-y-3">
          <button
            type="button"
            data-social="google"
            class="w-full inline-flex items-center justify-center h-11 rounded-md px-8 bg-cetus-accent text-cetus-surface font-bold transition-all duration-300 hover:bg-cetus-accent/90 focus:outline-none focus:ring-2 focus:ring-cetus-accent/50 text-sm"
          >
            <span class="flex items-center justify-center">
              Create account with Google
            </span>
          </button>

          <div
            id="error-message"
            role="alert"
            class="hidden p-4 bg-cetus-accent-3/10 border border-cetus-accent-3/30 rounded-lg text-cetus-accent-3 text-sm"
          >
          </div>
        </div>

        <!-- Login Link -->
        <div class="text-center mt-6 pt-6 border-t border-cetus-hairline">
          <p class="text-cetus-ink-muted">
            Already have an account?
            <a
              href="/login"
              class="text-cetus-accent hover:text-cetus-accent/80 transition-colors duration-300 font-medium"
            >
              Continue with Google
            </a>
          </p>
        </div>
      </Card>
    </Container>
  </Section>

  <script>
    import { authClient } from '@/lib/auth-client'

    document.addEventListener('DOMContentLoaded', () => {
      const errorMessage = document.getElementById('error-message')
      const googleBtn = document.querySelector(
        '[data-social="google"]'
      ) as HTMLButtonElement | null

      if (googleBtn) {
        googleBtn.addEventListener('click', async () => {
          hideError()

          const originalText = googleBtn.innerHTML
          googleBtn.innerHTML =
            '<span class="flex items-center justify-center">Connecting...</span>'
          googleBtn.disabled = true

          try {
            const result = await authClient.signIn.social({
              provider: 'google',
              callbackURL: '/?redirect=games',
            })

            if (result.error) {
              console.error(
                '[auth] Google sign-up failed:',
                result.error.message
              )
              showError(
                result.error.message ||
                  'Google sign up failed. Please try again.'
              )
              googleBtn.innerHTML = originalText
              googleBtn.disabled = false
              return
            }
          } catch (error) {
            console.error('[auth] Google sign-up error:', error)
            showError('Google sign up failed. Please try again.')
            googleBtn.innerHTML = originalText
            googleBtn.disabled = false
          }
        })
      }

      function hideError() {
        if (errorMessage) {
          errorMessage.classList.add('hidden')
        }
      }

      function showError(message: string) {
        if (errorMessage) {
          errorMessage.textContent = message
          errorMessage.classList.remove('hidden')
        } else {
          console.error('[auth] Unable to display error:', message)
        }
      }

      // Floating particles animation
      const particles = document.querySelectorAll(
        '.animate-bounce'
      ) as NodeListOf<HTMLElement>
      particles.forEach((particle, index) => {
        if (index % 2 === 0) {
          particle.classList.add('animate-float')
        }
      })
    })
  </script>
</AppLayout>
