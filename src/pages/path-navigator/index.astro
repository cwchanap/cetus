---
import GamePage from '@/components/games/GamePage.astro'
import Card from '@/components/ui/Card.astro'
import Badge from '@/components/ui/Badge.astro'
---

<GamePage
  gameId="path-navigator"
  title="Path Navigator"
  description="Guide your cursor through 4 challenging paths without touching the edges!"
  icon="🎯"
  overlayTitle="GAME OVER"
  showPause={false}
  showReset={false}
>
  <!-- Board: path-navigator canvas container -->
  <div slot="game-board">
    <div
      id="path-navigator-container"
      class="relative bg-black/50 rounded-lg"
      style="width: 800px; height: 600px;"
    >
    </div>
  </div>

  <!-- Additional stat: level -->
  <Badge slot="additional-stats" variant="outline" class="px-4 py-2">
    <span class="font-mono">Level: <span id="level">1</span></span>
  </Badge>

  <!-- Sidebar -->
  <div slot="game-info">
    <!-- Instructions -->
    <Card variant="glass" class="p-6">
      <h3 class="font-mono text-sm tracking-wide text-cetus-accent mb-4">
        ▸ HOW TO PLAY
      </h3>
      <div class="space-y-3 text-sm text-cetus-ink">
        <div class="flex items-start space-x-2">
          <span class="text-cetus-accent">•</span>
          <span>Move your mouse to control the cursor</span>
        </div>
        <div class="flex items-start space-x-2">
          <span class="text-cetus-accent">•</span>
          <span>Stay within the cyan path boundaries</span>
        </div>
        <div class="flex items-start space-x-2">
          <span class="text-cetus-accent">•</span>
          <span>Reach the green goal to complete each level</span>
        </div>
        <div class="flex items-start space-x-2">
          <span class="text-cetus-accent">•</span>
          <span>Complete all 4 levels before time runs out</span>
        </div>
        <div class="flex items-start space-x-2">
          <span class="text-red-400">•</span>
          <span>Game over if you leave the path!</span>
        </div>
      </div>
    </Card>

    <!-- Level Information -->
    <Card variant="glass" class="p-6">
      <h3 class="font-mono text-sm tracking-wide text-cetus-accent mb-4">
        ▸ LEVELS
      </h3>
      <div class="space-y-3 text-sm">
        <div class="flex justify-between items-center">
          <span class="text-cetus-ink-muted">Level 1:</span>
          <Badge variant="outline" class="px-2 py-1 text-xs">Easy Path</Badge>
        </div>
        <div class="flex justify-between items-center">
          <span class="text-cetus-ink-muted">Level 2:</span>
          <Badge variant="outline" class="px-2 py-1 text-xs">Curved Path</Badge>
        </div>
        <div class="flex justify-between items-center">
          <span class="text-cetus-ink-muted">Level 3:</span>
          <Badge variant="outline" class="px-2 py-1 text-xs">Zigzag Path</Badge>
        </div>
        <div class="flex justify-between items-center">
          <span class="text-cetus-ink-muted">Level 4:</span>
          <Badge variant="outline" class="px-2 py-1 text-xs">Spiral Path</Badge>
        </div>
      </div>
    </Card>

    <!-- Controls Guide -->
    <Card variant="glass" class="p-6">
      <h3 class="font-mono text-sm tracking-wide text-cetus-accent mb-4">
        ▸ CONTROLS
      </h3>
      <div class="space-y-2 text-sm">
        <div class="flex justify-between items-center">
          <span class="text-cetus-ink-muted">Mouse Movement:</span>
          <Badge variant="outline" class="px-2 py-1 text-xs">Navigate</Badge>
        </div>
        <div class="flex justify-between items-center">
          <span class="text-cetus-ink-muted">Start Game:</span>
          <Badge variant="outline" class="px-2 py-1 text-xs">Button</Badge>
        </div>
        <div class="flex justify-between items-center">
          <span class="text-cetus-ink-muted">Time Limit:</span>
          <Badge variant="outline" class="px-2 py-1 text-xs">60 seconds</Badge>
        </div>
        <div class="pt-2 border-t border-cetus-hairline">
          <div class="text-cetus-ink-muted text-xs">
            💡 Move smoothly and avoid sudden movements for better control!
          </div>
        </div>
      </div>
    </Card>

    <!-- Scoring -->
    <Card variant="glass" class="p-6">
      <h3 class="font-mono text-sm tracking-wide text-cetus-accent mb-4">
        ▸ SCORING
      </h3>
      <div class="space-y-2 text-sm">
        <div class="flex justify-between items-center">
          <span class="text-cetus-ink-muted">Level 1:</span>
          <span class="text-cetus-accent">100 + time bonus</span>
        </div>
        <div class="flex justify-between items-center">
          <span class="text-cetus-ink-muted">Level 2:</span>
          <span class="text-cetus-accent">200 + time bonus</span>
        </div>
        <div class="flex justify-between items-center">
          <span class="text-cetus-ink-muted">Level 3:</span>
          <span class="text-cetus-accent">300 + time bonus</span>
        </div>
        <div class="flex justify-between items-center">
          <span class="text-cetus-ink-muted">Level 4:</span>
          <span class="text-cetus-accent">500 + time bonus</span>
        </div>
        <div class="pt-2 border-t border-cetus-hairline">
          <div class="text-cetus-ink-muted text-xs">
            Time bonus = (15 - level_time) × level_multiplier
          </div>
        </div>
      </div>
    </Card>
  </div>

  <!-- Custom overlay stats (Final Score is rendered by GameOverlay itself) -->
  <div slot="final-stats">
    <div class="text-lg text-cetus-ink">
      Levels Completed: <span id="levels-completed" class="text-cetus-accent"
        >0</span
      >
    </div>
    <div class="text-lg text-cetus-ink">
      Total Time: <span id="total-time" class="text-cetus-accent">0</span>s
    </div>
  </div>
</GamePage>

<script>
  import { initPathNavigatorGameFramework } from '@/lib/games/path-navigator/initFramework'

  let cleanup: (() => void) | undefined

  document.addEventListener('DOMContentLoaded', async () => {
    try {
      const instance = await initPathNavigatorGameFramework()
      if (instance) {
        cleanup = instance.cleanup
      }
    } catch (error) {
      console.error('Failed to initialize Path Navigator game:', error)
    }
  })

  // Clean up on page unload
  window.addEventListener('beforeunload', () => {
    if (cleanup) {
      cleanup()
    }
  })
</script>
