---
import GamePage from '@/components/games/GamePage.astro'
import Card from '@/components/ui/Card.astro'
import Badge from '@/components/ui/Badge.astro'
---

<GamePage
  gameId="2048"
  title="2048"
  description="Slide tiles and combine matching numbers to reach 2048"
  icon="🎯"
>
  <!-- Board: 2048 tile grid + win notification -->
  <div slot="game-board">
    <div class="relative">
      <div
        id="game-2048-container"
        class="border-2 border-cetus-hairline bg-slate-900/50 rounded-lg touch-none"
        style="width: 410px; height: 410px;"
      >
      </div>

      <!-- Win Notification -->
      <div
        id="win-notification"
        class="hidden absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 bg-cetus-accent/90 text-white px-6 py-4 rounded-lg text-center z-50"
      >
        <div class="text-2xl font-bold mb-2">🎉 You reached 2048!</div>
        <div class="text-sm">Keep playing to reach higher scores!</div>
      </div>
    </div>
  </div>

  <!-- Additional stat badges (score-display / max-tile-display use game-specific IDs) -->
  <Badge slot="additional-stats" variant="outline" class="px-4 py-2">
    <span class="font-mono">Score: <span id="score-display">0</span></span>
  </Badge>
  <Badge slot="additional-stats" variant="outline" class="px-4 py-2">
    <span class="font-mono"
      >Best Tile: <span id="max-tile-display">0</span></span
    >
  </Badge>

  <!-- Sidebar -->
  <div slot="game-info">
    <!-- Controls Guide -->
    <Card variant="glass" class="p-6">
      <h3 class="font-mono text-sm tracking-wide text-cetus-accent mb-4">
        ▸ CONTROLS
      </h3>
      <div class="space-y-2 text-sm">
        <div class="flex justify-between">
          <span class="text-cetus-ink-muted">Slide Up:</span>
          <Badge variant="outline" class="px-2 py-1 text-xs">↑ / W</Badge>
        </div>
        <div class="flex justify-between">
          <span class="text-cetus-ink-muted">Slide Down:</span>
          <Badge variant="outline" class="px-2 py-1 text-xs">↓ / S</Badge>
        </div>
        <div class="flex justify-between">
          <span class="text-cetus-ink-muted">Slide Left:</span>
          <Badge variant="outline" class="px-2 py-1 text-xs">← / A</Badge>
        </div>
        <div class="flex justify-between">
          <span class="text-cetus-ink-muted">Slide Right:</span>
          <Badge variant="outline" class="px-2 py-1 text-xs">→ / D</Badge>
        </div>
        <div class="mt-4 pt-4 border-t border-cetus-hairline">
          <span class="text-cetus-ink-muted">Mobile:</span>
          <span class="text-cetus-accent ml-2">Swipe to move</span>
        </div>
      </div>
    </Card>

    <!-- How to Play -->
    <Card variant="glass" class="p-6">
      <h3 class="font-mono text-sm tracking-wide text-cetus-accent mb-4">
        ▸ HOW TO PLAY
      </h3>
      <div class="space-y-3 text-sm text-cetus-ink-muted">
        <p>Use arrow keys or swipe to slide all tiles in one direction.</p>
        <p>
          When two tiles with the same number touch, they merge into one with
          double the value.
        </p>
        <p>
          Reach the <span class="text-cetus-accent font-bold">2048</span> tile to
          win!
        </p>
        <p class="text-xs text-cetus-ink-muted">
          You can continue playing after reaching 2048.
        </p>
      </div>
    </Card>

    <!-- Tile Guide -->
    <Card variant="glass" class="p-6">
      <h3 class="font-mono text-sm tracking-wide text-cetus-accent mb-4">
        ▸ TILE PROGRESSION
      </h3>
      <div class="flex flex-wrap gap-2 text-xs font-mono">
        <span class="px-2 py-1 rounded bg-slate-800 text-cetus-accent">2</span>
        <span class="px-2 py-1 rounded bg-slate-700 text-cetus-accent">4</span>
        <span class="px-2 py-1 rounded bg-blue-900 text-white">8</span>
        <span class="px-2 py-1 rounded bg-purple-900 text-white">16</span>
        <span class="px-2 py-1 rounded bg-purple-700 text-white">32</span>
        <span class="px-2 py-1 rounded bg-red-600 text-white">64</span>
        <span class="px-2 py-1 rounded bg-red-400 text-slate-900">128</span>
        <span class="px-2 py-1 rounded bg-yellow-400 text-slate-900">256</span>
        <span class="px-2 py-1 rounded bg-green-500 text-slate-900">512</span>
        <span class="px-2 py-1 rounded bg-blue-400 text-white">1024</span>
        <span class="px-2 py-1 rounded bg-cyan-400 text-slate-900 font-bold"
          >2048</span
        >
      </div>
    </Card>
  </div>

  <!-- Custom overlay stats -->
  <div slot="final-stats">
    <div class="text-lg text-cetus-ink">
      Score: <span id="custom-final-score" class="text-cetus-accent">0</span>
    </div>
    <div class="text-lg text-cetus-ink">
      Max Tile: <span id="final-max-tile" class="text-cetus-accent">0</span>
    </div>
    <div class="text-lg text-cetus-ink">
      Moves: <span id="final-moves" class="text-green-400">0</span>
    </div>
  </div>
</GamePage>

<script>
  import { init2048GameFramework } from '@/lib/games/2048/initFramework'

  // Initialize game when page loads. All button/keyboard/touch wiring is
  // handled inside the framework initializer.
  document.addEventListener('DOMContentLoaded', async () => {
    try {
      const gameInstance = await init2048GameFramework()

      if (!gameInstance) {
        console.error('Failed to initialize 2048 game')
        return
      }

      // Expose game instance for debugging
      ;(window as any).game2048 = gameInstance
    } catch (error) {
      console.error('Failed to initialize 2048 game:', error)
    }
  })
</script>
