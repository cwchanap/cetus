---
import GamePage from '@/components/games/GamePage.astro'
import Card from '@/components/ui/Card.astro'
import Badge from '@/components/ui/Badge.astro'
import Button from '@/components/ui/Button.astro'
---

<GamePage
  gameId="bubble-shooter"
  title="Bubble Shooter"
  description="Match 3 or more bubbles of the same color to clear them"
  icon="🫧"
>
  <!-- Board mount + pause overlay -->
  <div slot="game-board">
    <div class="relative">
      <div
        id="game-container"
        class="border-2 border-cetus-hairline bg-black/50 rounded-lg"
        style="width: 600px; height: 800px;"
      >
      </div>

      <!-- Pause Overlay -->
      <div
        id="pause-overlay"
        class="absolute inset-0 bg-black/80 rounded-lg flex items-center justify-center hidden"
      >
        <div class="text-center">
          <h3
            class="text-3xl font-mono font-bold text-cetus-accent mb-4 cetus-wordmark"
            style="font-family: var(--cetus-display-font);"
          >
            PAUSED
          </h3>
          <Button id="resume-btn" variant="primary">Resume</Button>
        </div>
      </div>
    </div>
  </div>

  <!-- Additional stat: bubbles remaining -->
  <Badge slot="additional-stats" variant="outline" class="px-4 py-2">
    <span class="font-mono">Bubbles: <span id="bubbles-remaining">0</span></span
    >
  </Badge>

  <!-- Sidebar -->
  <div slot="game-info">
    <!-- Current Bubble -->
    <Card variant="glass" class="p-6">
      <h3
        class="font-mono text-sm tracking-wide text-cetus-accent mb-4 text-center"
      >
        ▸ CURRENT BUBBLE
      </h3>
      <div class="flex justify-center">
        <canvas
          id="current-bubble"
          width="64"
          height="64"
          class="rounded-full shadow-lg"></canvas>
      </div>
    </Card>

    <!-- Next Bubble -->
    <Card variant="glass" class="p-6">
      <h3
        class="font-mono text-sm tracking-wide text-purple-400 mb-4 text-center"
      >
        ▸ NEXT BUBBLE
      </h3>
      <div class="flex justify-center">
        <canvas
          id="next-bubble"
          width="48"
          height="48"
          class="rounded-full shadow-lg"></canvas>
      </div>
    </Card>

    <!-- Controls Guide -->
    <Card variant="glass" class="p-6">
      <h3 class="font-mono text-sm tracking-wide text-cetus-accent mb-4">
        ▸ CONTROLS
      </h3>
      <div class="space-y-2 text-sm">
        <div class="flex justify-between">
          <span class="text-cetus-ink-muted">Aim:</span>
          <Badge variant="outline" class="px-2 py-1 text-xs">Mouse</Badge>
        </div>
        <div class="flex justify-between">
          <span class="text-cetus-ink-muted">Shoot:</span>
          <Badge variant="outline" class="px-2 py-1 text-xs">Click</Badge>
        </div>
        <div class="flex justify-between">
          <span class="text-cetus-ink-muted">Pause:</span>
          <Badge variant="outline" class="px-2 py-1 text-xs">P</Badge>
        </div>
      </div>
    </Card>

    <!-- Game Rules -->
    <Card variant="glass" class="p-6">
      <h3 class="font-mono text-sm tracking-wide text-purple-400 mb-4">
        ▸ RULES
      </h3>
      <div class="space-y-2 text-sm text-cetus-ink">
        <p>• Match 3+ bubbles of the same color</p>
        <p>• Bubbles must be connected to pop</p>
        <p>• New row appears after each shot</p>
        <p>• Game ends when bubbles reach bottom</p>
        <p>• Higher combos = more points</p>
      </div>
    </Card>
  </div>

  <!-- Custom overlay stats -->
  <div slot="final-stats">
    <div class="text-lg text-cetus-ink">
      Bubbles Popped: <span id="final-bubbles-popped" class="text-cetus-accent"
        >0</span
      >
    </div>
    <div class="text-lg text-cetus-ink">
      Shots Fired: <span id="final-shots" class="text-cetus-accent">0</span>
    </div>
    <div class="text-lg text-cetus-ink">
      Accuracy: <span id="final-accuracy" class="text-cetus-accent-3">0%</span>
    </div>
    <div class="text-lg text-cetus-ink">
      Largest Combo: <span id="final-combo" class="text-cetus-accent-2">0</span>
    </div>
  </div>
</GamePage>

<script>
  import { initBubbleShooterGameFramework } from '@/lib/games/bubble-shooter/initFramework'

  // Initialize game when page loads
  document.addEventListener('DOMContentLoaded', async () => {
    try {
      await initBubbleShooterGameFramework()
      console.log('Bubble Shooter game initialized successfully')
    } catch (error) {
      console.error('Failed to initialize Bubble Shooter game:', error)
    }
  })
</script>
